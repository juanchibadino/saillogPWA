# Required public Supabase config (safe for browser use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional but recommended canonical app URL for magic-link redirects
# Local example: http://localhost:3000
# Production example: https://sailog.vercel.app
NEXT_PUBLIC_APP_URL=

# Optional server-only key for trusted admin operations
SUPABASE_SECRET_KEY=

# Optional project ref used by CLI scripts and tooling
SUPABASE_PROJECT_REF=

# Legacy fallbacks (optional)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
