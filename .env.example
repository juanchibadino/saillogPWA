# Required public Supabase config (safe for browser use)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional but recommended canonical app URL for magic-link redirects
# Local example: http://localhost:3000
# Production example: https://sailog.vercel.app
NEXT_PUBLIC_APP_URL=

# Optional server-only key for trusted admin operations
SUPABASE_SECRET_KEY=

# Optional project ref used by CLI scripts and tooling
SUPABASE_PROJECT_REF=

# PayPal billing (MVP)
# PAYPAL_ENV defaults to sandbox when empty.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PRO_MONTHLY_PLAN_ID=
PAYPAL_PRO_YEARLY_PLAN_ID=

# Legacy fallbacks (optional)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
